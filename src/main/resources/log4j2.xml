<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <!-- Console 現在顯示 DEBUG 以上的日誌 -->
        <Console name="Console" target="SYSTEM_OUT">
            <ThresholdFilter level="debug"/>  <!-- ✅ 改為 `debug`，這樣 `LOGGER.debug()` 會顯示 -->
            <PatternLayout pattern="%d{HH:mm:ss} [%level] [%logger{1}] %msg%n"/>
        </Console>

        <!-- 記錄 DEBUG 到 `logs/debug/debug.log` -->
        <RollingFile name="DebugFile"
                     fileName="logs/debug/debug.log"
                     filePattern="logs/debug/debug-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%level] [%logger{1}] %msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy />
            </Policies>
        </RollingFile>
    </Appenders>

    <Loggers>
        <!-- ✅ 直接把 `level` 設為 `debug`，避免環境變數影響 -->
        <Logger name="com.github.nalamodikk" level="debug" additivity="false">
            <AppenderRef ref="Console"/> <!-- ✅ `DEBUG` 也顯示在 Console -->
            <AppenderRef ref="DebugFile"/>
        </Logger>

        <!-- 根日誌等級設為 `debug`，讓所有 Log4j 記錄都包含 `DEBUG` -->
        <Root level="debug">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="DebugFile"/>
        </Root>
    </Loggers>
</Configuration>
